# Spotify Client-ID aus dem Developer Dashboard (https://developer.spotify.com/dashboard).
# Kopiere diese Datei nach `.env` und trage deine Client-ID ein.
# Es ist KEIN Client-Secret nötig (PKCE-Flow, client-only).
VITE_SPOTIFY_CLIENT_ID=

# Redirect URI — MUSS exakt so im Spotify Dashboard hinterlegt sein.
# Loopback-IP, NICHT localhost (Spotify lehnt localhost ab).
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
